# Alpaca API (required)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_PAPER=true

# Finnhub (optional — for news sentiment & discovery)
FINNHUB_API_KEY=your_finnhub_api_key

# Broker selection (optional — default: alpaca)
STOCKS_BROKER=alpaca
POLYGON_API_KEY=your_polygon_api_key
USE_EMAIL_NOTIFICATIONS=true
EMAIL_TO_ADDRESSES=your_email@example.com
EMAIL_FROM_ADDRESS=your_email@example.com
EMAIL_SMTP_USER=your_email@example.com
EMAIL_SMTP_PASSWORD=your_smtp_app_password